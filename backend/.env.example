PORT=4000

# --- Postgres (discrete env only; use docker-compose or local instance) ---
# PG_HOST=127.0.0.1
# PG_PORT=5433
# PG_USER=bench
# PG_PASSWORD=benchdev
# PG_DATABASE=socialbench
# PG_SSL=off
#
# Remote TLS: PG_SSL=require
# PG_SSL_REJECT_UNAUTHORIZED=0   # only if you need relaxed cert verify

# Schema: from backend/,  npm run migrate   then   npm run seed

# Optional: set to 1 to log SQL from TypeORM
TYPEORM_LOGGING=0

# Redis (HTTP response cache for GET + res.json). Leave unset to disable cache middleware.
REDIS_URL=
REDIS_CACHE_TTL_SECONDS=60

# JWT — access tokens (API requests). Legacy: JWT_SECRET still works if JWT_ACCESS_SECRET is unset.
JWT_SECRET=
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m

# JWT — refresh tokens (only /api/auth/refresh). Must be different from the access secret in production.
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# When true, POST /api/auth/token can mint tokens for an existing user id (local dev only)
AUTH_ISSUE_DEV_TOKENS=false

# When 1, all /api/* routes except /api/health and /api/auth/* require Authorization: Bearer <access_token>
AUTH_GLOBAL_PROTECT=0
