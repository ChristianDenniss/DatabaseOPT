{
  "name": "databaseopt-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "kill:port": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "node scripts/seed.mjs",
    "migrate": "tsx src/run-migrations.ts",
    "migrate:revert": "tsx src/run-migrations.ts revert"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
